{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react", 
    "allowSyntheticDefaultImports": true, 
    "module": "esnext",
    "moduleResolution": "bundler", 
    "types": ["@astrojs/ts-plugin"], 
    "allowJs": true, 
    "resolveJsonModule": true
  }
}