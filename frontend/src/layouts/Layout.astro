---
import { createTranslations } from "../core/shared/infrastructure/i18n/server";

const { title = "Jeseb Hub" } = Astro.props;

const locale = Astro.props?.locale || "en";
const t = createTranslations(locale);
---

<!doctype html>
<html lang={locale} data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon/icon.svg" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon/icon.svg" />
		<link rel="shortcut icon" href="/favicon/icon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="locale" content={locale} />
		<meta name="description" content={t("og.description")} />
		<!-- Whatsapp & Social media -->
		<meta property="og:title" content={t("og.title")} />
		<meta property="og:description" content={t("og.description")} />
		<meta property="og:image" content="/favicon/og.png" />
		<meta property="og:image:width" content="300" />
		<meta property="og:image:height" content="300" />
		<meta property="og:type" content="website">
		<meta property="og:url" content="https://hub.jeseb.com/" />
		<!-- Android -->
		<link rel="manifest" href="/favicon/site.webmanifest" />
		<!-- IOS -->
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple.png" />
		<title>{title}</title>
		<style>
			html, body {
				margin: 0;
				width: 100%;
				height: 100%;
			}
		</style>
		<script>
			import { initTranslations, type Locale } from "../core/shared/infrastructure/i18n";

			const metaLocale = document.querySelector(`meta[name="locale"]`)?.getAttribute("content");
			if (metaLocale) initTranslations(metaLocale as Locale);
			else initTranslations();
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
