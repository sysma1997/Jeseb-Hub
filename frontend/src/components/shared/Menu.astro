---
import { Icon } from "astro-icon/components";
import { createTranslations } from "../../core/shared/infrastructure/i18n/server";

import Dropdown from "./Dropdown.astro";

import "../../styles/shared/menu.css";

const locale = Astro.props?.locale || "en";
const t = createTranslations(locale);
---

<nav class="menu">
    <div class="menu-content">
        <div class="menu-desktop">
            <div class="menu-item">
                <Dropdown id="theme" icon="material-symbols:sunny-snowing-rounded" label={t("theme.title")} items={[
                    { label: t("theme.light"), icon: "solar:sun-2-bold", value: "light" }, 
                    { label: t("theme.dark"), icon: "solar:moon-bold", value: "dark" }, 
                ]} />
            </div>
            <div class="menu-item">
                <Dropdown id="locale" icon="material-symbols:language" label={t("locales.title")} items={[
                    { label: t("locales.en"), value: "en" }, 
                    { label: t("locales.es"), value: "es" }
                ]} value={locale} />
            </div>

            <div class="separator"></div>

            <div class="menu-item">
                <button class="menu-trigger" id="userMenuBtn">
                    <div id="userAvatar" class="menu-user-avatar">
                        <Icon name="material-symbols:person-rounded" width={18} />
                    </div>
                    <span id="userNameDisplay" class="menu-user-name"></span>
                </button>
                <div class="menu-dropdown">
                    <a class="menu-dropdown-item" href={`/${locale}/profile`}>
                        <Icon name="solar:user-bold" />
                        {t("shared.menu.profile")}
                    </a>
                    <button id="desktopLogout" class="menu-dropdown-item">
                        <Icon name="material-symbols:logout" />
                        {t("shared.menu.logout")}
                    </button>
                </div>
            </div>
        </div>

        <div class="menu-mobile">
            <a class="sidebar-logo-icon" href={`/${locale}`}>
                <img id="logoImg" src="/favicon/icon-dark.svg" alt="Jeseb Hub" />
            </a>
            <div class="menu-mobile-options">
                <button id="mobileThemeBtn" class="menu-mobile-btn">
                    <Icon name="material-symbols:sunny-snowing-rounded" width={20} />
                </button>
                <button id="mobileLocaleBtn" class="menu-mobile-btn">
                    <Icon name="material-symbols:language" width={20} />
                </button>
                <div class="menu-item">
                    <button class="menu-trigger" style="padding: 0.5rem;">
                        <div id="mobileUserAvatar" class="menu-user-avatar" style="width: 32px; height: 32px;">
                            <Icon name="material-symbols:person-rounded" width={18} />
                        </div>
                    </button>
                    <div class="menu-dropdown">
                        <a id="mobileProfile" class="menu-dropdown-item" href={`/${locale}/profile`}>
                            <Icon name="solar:user-bold" />
                            {t("shared.menu.profile")}
                        </a>
                        <button id="mobileLogout" class="menu-dropdown-item">
                            <Icon name="material-symbols:logout" />
                            {t("shared.menu.logout")}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>

<script>
    import { Api } from "../../core/shared/infrastructure/Api";
    import { User } from "../../core/user/domain/User";
    import type { UserRepository } from "../../core/user/domain/UserRepository";
    import { UserApiRepository } from "../../core/user/infrastructure/UserApiRepository";
    import { type Locale, getLocale, setLocale } from "../../core/shared/infrastructure/i18n";

    (async () => {
        const userRepository: UserRepository = new UserApiRepository();
        const currentLocale = getLocale();

        // Elementos desktop
        const desktopLogout = document.getElementById("desktopLogout");
        const userNameDisplay = document.getElementById("userNameDisplay");
        const userAvatar = document.getElementById("userAvatar");
        
        // Elementos móvil
        const mobileThemeBtn = document.getElementById("mobileThemeBtn");
        const mobileLocaleBtn = document.getElementById("mobileLocaleBtn");
        const mobileLogout = document.getElementById("mobileLogout");
        const mobileUserAvatar = document.getElementById("mobileUserAvatar");

        // Cambiar tema
        function setTheme(theme: string) {
            localStorage.setItem("theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            document.cookie = `theme=${theme};path=/;max-age=31536000;SameSite=Lax`;
            
            const icon = document.getElementById("icon") as HTMLImageElement;
            if (icon) {
                icon.src = theme === "dark" ? "/favicon/icon-dark.svg" : "/favicon/icon.svg";
            }
        }
        
        // Ciclar tema (para móvil)
        function cycleTheme() {
            const current = localStorage.getItem("theme") || "light";
            const newTheme = current === "light" ? "dark" : "light";
            setTheme(newTheme);
        }
        // Ciclar idioma (para móvil)
        function cycleLanguage() {
            const current = getLocale();
            const newLang = current === "en" ? "es" : "en";
            setLocale(newLang as Locale);
            let split = window.location.pathname.split("/");
            split[1] = split[1].replace(currentLocale, newLang);
            window.location.href = split.join("/");
        }
        
        // Tema inicial
        const currentTheme = localStorage.getItem("theme") || "light";
        setTheme(currentTheme);
        
        // Eventos móvil
        if (mobileThemeBtn) mobileThemeBtn.onclick = cycleTheme;
        if (mobileLocaleBtn) mobileLocaleBtn.onclick = cycleLanguage;

        const themeDropdown = document.getElementById("themeDropdown");
        const localesDropdown = document.getElementById("localeDropdown");

        themeDropdown?.addEventListener("dropdown-select", (event: Event) => {
            const theme = (event as CustomEvent).detail.value;
            
            window.localStorage.setItem("theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            document.cookie = `theme=${theme};path=/;max-age=31536000;SameSite=Lax`;
        });
        localesDropdown?.addEventListener("dropdown-select", (event: Event) => {
            const locale = (event as CustomEvent).detail.value;
            setLocale(locale as Locale);

            let pathname: string = window.location.pathname;
            pathname = pathname.replace(currentLocale, locale);
            window.location.href = pathname;
        });
        
        // Cargar usuario
        try {
            const user: User | undefined = await userRepository.get();
            if (!user) {
                window.location.href = `/${currentLocale}/login`;
                return;
            }
            
            // Mostrar nombre desktop
            if (userNameDisplay) {
                userNameDisplay.textContent = user.name;
            }
            
            // Mostrar avatar desktop
            if (user.profile && userAvatar) {
                const img = document.createElement("img");
                img.src = `${Api.BackendUrl}${user.profile}`;
                img.style.width = "32px";
                img.style.height = "32px";
                img.style.borderRadius = "50%";
                img.style.objectFit = "cover";
                userAvatar.innerHTML = "";
                userAvatar.appendChild(img);
            }
            
            // Mostrar avatar móvil
            if (user.profile && mobileUserAvatar) {
                const img = document.createElement("img");
                img.src = `${Api.BackendUrl}${user.profile}`;
                img.style.width = "32px";
                img.style.height = "32px";
                img.style.borderRadius = "50%";
                img.style.objectFit = "cover";
                mobileUserAvatar.innerHTML = "";
                mobileUserAvatar.appendChild(img);
            }
            
            // Logout
            const handleLogout = () => {
                localStorage.removeItem("token");
                window.location.href = `/${currentLocale}/login`;
            };
            
            if (desktopLogout) desktopLogout.onclick = handleLogout;
            if (mobileLogout) mobileLogout.onclick = handleLogout;
            
        } catch (error) {
            console.error("Error loading user:", error);
            window.location.href = `/${currentLocale}/login`;
        }
    })();
</script>