---
import type { GetStaticPaths } from "astro";
import { getLocaleFromUrl, createTranslations } from "../../core/shared/infrastructure/i18n/server";

import Layout from "../../layouts/Layout.astro";
import Options from "../../components/shared/Options.astro";
import Form from "../../components/Form.astro";

import "../../styles/validation.css";

export const getStaticPaths = (() => {
    return [
        { params: { lang: "en" } }, 
		{ params: { lang: "es" } }
    ];
}) satisfies GetStaticPaths;

const locale = getLocaleFromUrl(Astro.url);
const t = createTranslations(locale);
---

<Layout locale={locale} title={t("validation.title")}>
    <Options locale={locale} />
    <div class="container">
        <img id="icon" src="/favicon/icon.svg" alt="Jeseb Hub" />
        <script is:inline>
			(function() {
				const theme = localStorage.getItem('theme');
				const id = document.getElementById("icon");
                id.src = (theme === "dark") ? "/favicon/icon-dark.svg" : "/favicon/icon.svg";
			})();
		</script>
        <Form title={t("validation.title")}>
            <div class="content">
                <p id="pMessage">{t("validation.description")}</p>
            </div>
            <button id="btnValidating" class="button is-primary is-fullwidth is-loading" disabled>Login</button>
        </Form>
    </div>

    <script>import "../../scripts/validation";</script>
</Layout>