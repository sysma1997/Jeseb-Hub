---
import type { GetStaticPaths } from "astro";
import { getLocaleFromUrl, createTranslations } from "../../core/shared/infrastructure/i18n/server";

import Layout from "../../layouts/Layout.astro";
import Locale from "../../layouts/Locale.astro";

import Form from "../../components/Form.astro";
import Alert from "../../components/modals/Alert.astro";

import jeseb from "../../assets/images/jeseb.png";

import "../../styles/register.css";

export const getStaticPaths = (() => {
	return [
		{ params: { lang: "en" } }, 
		{ params: { lang: "es" } }
	];
}) satisfies GetStaticPaths;

const locale = getLocaleFromUrl(Astro.url);
const t = createTranslations(locale);
---

<Layout locale={locale} title={t("register.title")}>
    <Locale locale={locale} />
    <div class="container">
        <img class="icon" src={jeseb.src} alt="Jeseb Hub" />
        <Form title={t("register.title")}>
            <div class="field">
                <label class="label">{t("shared.name")}</label>
                <div class="control">
                    <input id="inName" class="input" type="text" />
                </div>
            </div>
            <div class="field">
                <label class="label">{t("shared.email")}</label>
                <div class="control">
                    <input id="inEmail" class="input" type="email" />
                </div>
            </div>
            <div class="field">
                <label class="label">{t("shared.password")}</label>
                <div class="control">
                    <input id="inPassword" class="input" type="password" />
                </div>
            </div>
            <div class="field">
                <label class="label">{t("shared.passwordConfirm")}</label>
                <div class="control">
                    <input id="inConfirmPassword" class="input" type="password" />
                </div>
            </div>
            
            <div class="info">
                <label>{t("register.login.description")} <a href=`/${locale}/login`>{t("register.login.link")}</a>.</label>
            </div>

            <div class="field">
                <div class="control">
                    <button id="btnRegister" class="button is-primary is-fullwidth">{t("register.register")}</button>
                </div>
            </div>
        </Form>
    </div>

    <Alert locale={locale} />

    <script>import "../../scripts/register";</script>
</Layout>