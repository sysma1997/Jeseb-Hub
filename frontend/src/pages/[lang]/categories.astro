---
import type { GetStaticPaths } from "astro";
import { getLocaleFromUrl, createTranslations } from "../../core/shared/infrastructure/i18n/server";

import { Icon } from "astro-icon/components";

import Layout from "../../layouts/Layout.astro";
import Content from "../../components/shared/Content.astro";

import Alert from "../../components/modals/Alert.astro";
import Prompt from "../../components/modals/Prompt.astro";
import Confirm from "../../components/modals/Confirm.astro";

import { List } from "../../components/categories/List";

import "../../styles/categories/index.css";

export const getStaticPaths = (() => {
    return [
        { params: { lang: "en" } }, 
        { params: { lang: "es" } }
    ];
}) satisfies GetStaticPaths;

const locale = getLocaleFromUrl(Astro.url);
const t = createTranslations(locale);
---

<Layout locale={locale} title={t("category.title")}>
    <Content locale={locale}>
        <div class="categories">
            <div class="categoriesContent">
                <List client:only="read" />
            </div>
        </div>
    </Content>

    <Prompt locale={locale} />
    <Confirm locale={locale} />
    <Alert locale={locale} />
    <script>import "../../scripts/categories";</script>
</Layout>