---
import type { GetStaticPaths } from "astro";
import { getLocaleFromUrl, createTranslations } from "../../core/shared/infrastructure/i18n/server";

import Layout from "../../layouts/Layout.astro";
import Locale from "../../layouts/Locale.astro";

import Form from "../../components/Form.astro";
import Base from "../../components/modals/Base.astro";
import Alert from "../../components/modals/Alert.astro";

import jeseb from "../../assets/images/jeseb.png";

import "../../styles/login.css";

export const getStaticPaths = (() => {
	return [
		{ params: { lang: "en" } }, 
		{ params: { lang: "es" } }
	];
}) satisfies GetStaticPaths;

const locale = getLocaleFromUrl(Astro.url);
const t = createTranslations(locale);
---

<Layout locale={locale} title={t("login.title")}>
    <Locale locale={locale} />
    <div class="container">
        <img class="icon" src={jeseb.src} alt="Jeseb Hub" />
        <Form title={t("login.title")}>
            <div class="field">
                <label class="label">{t("shared.email")}</label>
                <div class="control">
                    <input id="inEmail" class="input" type="email" />
                </div>
            </div>
            <div class="field">
                <label class="label">{t("shared.password")}</label>
                <div class="control">
                    <input id="inPassword" class="input" type="password" />
                </div>
            </div>
            
            <div class="info">
                <label>{t("login.passwordRecovery.description")} <a href={`/${locale}/recover`}>{t("login.passwordRecovery.link")}</a>.</label>
                <label>{t("login.register.description")} <a href={`/${locale}/register`}>{t("login.register.link")}</a>.</label>
            </div>

            <div class="field">
                <div class="control">
                    <button id="btnLogin" class="button is-primary is-fullwidth">{t("login.signIn")}</button>
                </div>
            </div>
        </Form>
    </div>

    <Base id="mTwoStep" title={t("shared.codeVerification")}>
        <section class="modal-card-body">
            <div class="field">
                <label id="mtsMessage" class="label">{t("shared.codeVerification")}</label>
                <div class="control">
                    <input id="iMTSCode" class="input" type="number" />
                </div>
            </div>
        </section>
        <footer class="modal-card-foot" style="gap: 0.5rem;">
            <button id="btnMTSCancel" class="button is-danger is-fullwidth">{t("shared.cancel")}</button>
            <button id="btnMTSAccept" class="button is-primary is-fullwidth">{t("shared.accept")}</button>
        </footer>
    </Base>
    <Alert locale={locale} />

    <script>import "../../scripts/login";</script>
</Layout>