---
import { Icon } from "astro-icon/components";

import Layout from "../layouts/Layout.astro";
import Menu from "../layouts/Menu.astro";

import Base from "../components/modals/Base.astro";
import Alert from "../components/modals/Alert.astro";
import Confirm from "../components/modals/Confirm.astro";

import { TransactionList } from "../components/index/TransactionList";

import "../styles/index/index.css";
---

<Layout>
	<Menu />
	
	<div class="transactions">
        <div class="transactionsContent">
			<TransactionList client:load />
        </div>
    </div>

	<button id="btnAddTransaction" class="button is-primary">
		<Icon name="material-symbols:add-2-rounded" width={24} height={24} />
    </button>

	<Base id="modalAddTransaction" title="Add transaction">
		<section id="sMAT1" class="modal-card-body" style="display: block;">
			<div class="field">
				<label class="label">Account:</label>
				<div class="control">
					<div class="select is-fullwidth">
						<select id="sMATAccount"></select>
					</div>
				</div>
			</div>
			<label id="lMATAccountBalance">Balance: 0</label>
		</section>
		<section id="sMAT2" class="modal-card-body" style="display: none;">
			<div class="field">
				<label class="label">Type:</label>
				<div class="control">
					<div class="select is-fullwidth">
						<select id="sMATType">
							<option value="true">Ingress</option>
							<option value="false">Egress</option>
						</select>
					</div>
				</div>
			</div>
			<div class="field">
				<label class="label">Value:</label>
				<div class="control">
					<input id="iMATValue" class="input" type="number" />
				</div>
			</div>
		</section>
		<section id="sMAT3" class="modal-card-body" style="display: none;">
			<p style="margin-bottom: 1.5rem;">The following options are optional.</p>
			<div class="field">
				<label class="label">Date:</label>
				<div class="control">
					<input id="iMATDate" class="input" type="datetime-local" />
				</div>
			</div>
			<div class="field">
				<label class="label">Category:</label>
				<div class="control">
					<div class="select is-fullwidth">
						<select id="sMATCategory"></select>
					</div>
				</div>
			</div>
			<div class="field">
				<label class="label">Description:</label>
				<div class="control">
					<textarea id="taMATDescription" class="textarea" />
				</div>
			</div>
		</section>
		<section id="sMAT4" class="modal-card-body" style="display: none;">
			<p style="margin-bottom: 1.5rem;">Please confirm the following information to create the transaction:</p>
			<div class="item">
				<label class="label">Account:</label>
				<p id="pMATAccountConfirm">.</p>
			</div>
			<div class="item">
				<label class="label">Type:</label>
				<p id="pMATTypeConfirm">.</p>
			</div>
			<div class="item">
				<label class="label">Value:</label>
				<p id="pMATValueConfirm">.</p>
			</div>
			<div class="item">
				<label class="label">Date:</label>
				<p id="pMATDateConfirm">.</p>
			</div>
			<div id="dMATCategoryConfirm" class="item" style="display: none;">
				<label class="label">Category:</label>
				<p id="pMATCategoryConfirm">.</p>
			</div>
			<div id="dMATDescriptionConfirm" class="item" style="display: none;">
				<label class="label">Description:</label>
				<p id="pMATDescriptionConfirm">.</p>
			</div>
		</section>
		<section id="sMAT5" class="modal-card-body" style="display: none;">
			<p id="pMATMessage">The transaction has been created successfully.</p>
		</section>
		<footer class="modal-card-foot" style="gap: 0.5rem;">
            <button id="btnMATCancel" class="button is-danger is-fullwidth">Cancel</button>
            <button id="btnMATAccept" class="button is-primary is-fullwidth">Next</button>
        </footer>
	</Base>
	<Base id="modalTransaction" title="Transaction">
		<section class="modal-card-body">
			<div class="item">
				<label class="label">Account:</label>
				<p id="pMTAccount">.</p>
			</div>
			<div class="item">
				<label class="label">Type:</label>
				<p id="pMTType">.</p>
			</div>
			<div class="item">
				<label class="label">Value:</label>
				<p id="pMTValue">.</p>
			</div>
			<div class="item">
				<label class="label">Date:</label>
				<p id="pMTDate">.</p>
			</div>
			<div id="dMTCategory" class="item" style="display: none;">
				<label class="label">Category:</label>
				<p id="pMTCategory">.</p>
			</div>
			<div id="dMTDescription" class="item" style="display: none;">
				<label class="label">Description:</label>
				<p id="pMTDescription">.</p>
			</div>
		</section>
		<footer class="modal-card-foot" style="gap: 0.5rem;">
            <button id="btnMTOk" class="button is-primary is-fullwidth">Ok</button>
        </footer>
	</Base>
	<Confirm />
	<Alert />
	<script>import "../scripts/index";</script>
</Layout>
