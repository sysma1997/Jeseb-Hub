---
import type { GetStaticPaths } from "astro";
import { getLocaleFromUrl } from "../core/shared/infrastructure/i18n/server";

import Layout from "../layouts/Layout.astro";

import "bulma/css/bulma.min.css";

export const getStaticPaths = (() => {
	return [
		{ params: { lang: "en" } }, 
		{ params: { lang: "es" } }
	];
}) satisfies GetStaticPaths;

const locale = getLocaleFromUrl(Astro.url);
---

<Layout locale={locale} title="Jeseb Hub">
    <style>
        .splash-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #00d1b2 0%, #00a896 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        .splash-logo {
            width: 100px;
            height: 100px;
            background: white;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: bounce 0.6s ease-out;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
        }

        .splash-logo img {
            width: 60px;
            height: 60px;
        }

        @keyframes bounce {
            0% {
                transform: scale(0.3);
                opacity: 0;
            }
            50% {
                transform: scale(1.1);
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .splash-title {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-top: 1.5rem;
            animation: fadeIn 0.6s ease-out 0.2s both;
        }

        .splash-spinner {
            margin-top: 2rem;
            width: 40px;
            height: 40px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <div class="splash-screen">
        <div class="splash-logo">
            <img id="logoImg" src="/favicon/icon.svg" alt="Jeseb Hub" />
        </div>
        <div class="splash-title">Jeseb Hub</div>
        <div class="splash-spinner"></div>
    </div>

    <script>
        import { getLocale, initTranslations } from "../core/shared/infrastructure/i18n";
        
        (async () => {
            await initTranslations();
            const locale = getLocale();
            
            // Pequeño delay para mostrar el splash
            setTimeout(() => {
                window.location.href = `/${locale}/`;
            }, 1000);
        })();
    </script>
</Layout>