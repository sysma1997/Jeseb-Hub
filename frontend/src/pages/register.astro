---
import Layout from "../layouts/Layout.astro";

import Form from "../components/Form.astro";
import Alert from "../components/modals/Alert.astro";

import "../styles/register.css";
---

<Layout title="Register">
    <div class="container">
        <img class="icon" src="/assets/images/OpenLedger_Hub.png" alt="OpenLedger Hub" />
        <Form title="Register">
            <div class="field">
                <label class="label">Name</label>
                <div class="control">
                    <input id="inName" class="input" type="text" />
                </div>
            </div>
            <div class="field">
                <label class="label">Email</label>
                <div class="control">
                    <input id="inEmail" class="input" type="email" />
                </div>
            </div>
            <div class="field">
                <label class="label">Password</label>
                <div class="control">
                    <input id="inPassword" class="input" type="password" />
                </div>
            </div>
            <div class="field">
                <label class="label">Confirm password</label>
                <div class="control">
                    <input id="inConfirmPassword" class="input" type="password" />
                </div>
            </div>
            
            <div class="info">
                <label>Do you already have a user account? <a href="/login">Login</a>.</label>
            </div>

            <div class="field">
                <div class="control">
                    <button id="btnRegister" class="button is-primary is-fullwidth">Register</button>
                </div>
            </div>
        </Form>
    </div>

    <Alert />

    <script type="module" src="/src/scripts/register.ts"></script>
</Layout>